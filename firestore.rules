rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only Firebase Auth'd user (the single admin account) has admin rights
    function isAdmin() {
      return request.auth != null;
    }

    // ── Config ─────────────────────────────────────────────────────────────
    match /config/settings {
      allow read: if true;          // Public: members read event settings
      allow write: if isAdmin();
    }
    match /config/admin {
      allow read, write: if isAdmin();
    }

    // ── Members ────────────────────────────────────────────────────────────
    match /members/{memberId} {
      // Public read: needed for T/F verification in Find Fellow game
      allow read: if true;
      // Anyone can register (create)
      allow create: if true;
      // Member updates own doc (accessCode must match), or admin
      allow update: if isAdmin()
                    || (request.resource.data.accessCode == resource.data.accessCode);
      allow delete: if isAdmin();

      match /badges/{badgeId} {
        allow read: if true;
        // Badge unlocks triggered by member client (validated in JS) or admin
        allow write: if true;
      }

      match /fellowScans/{targetId} {
        allow read:  if true;
        allow write: if true;
      }
    }

    // ── Teams ──────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Quiz Questions ─────────────────────────────────────────────────────
    match /quizQuestions/{qId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── T/F Statements ─────────────────────────────────────────────────────
    match /trueFalseStatements/{sId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── BOL Members ────────────────────────────────────────────────────────
    match /bolMembers/{bId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Leaderboard ────────────────────────────────────────────────────────
    match /leaderboard/{doc=**} {
      allow read:  if true;
      allow write: if true;   // Updated by member client on badge unlock
    }

    // ── Scan Logs ──────────────────────────────────────────────────────────
    match /scanLogs/{logId} {
      allow read:   if isAdmin();
      allow create: if true;
    }

    // ── Sonar Radar locations (ephemeral, event-only) ──────────────────────
    match /memberLocations/{memberId} {
      allow read:  if true;
      allow write: if true;
    }
  }
}
